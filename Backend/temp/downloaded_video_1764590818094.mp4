ED"},{"startIndex":676,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":681,"length":18,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":699,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":704,"length":19,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":723,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":728,"length":12,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":740,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":745,"length":19,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":764,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":769,"length":171,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":940,"length":52,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"}],"backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294963952,"raisedBackground":4294963952,"additiveBackground":568412205,"textPrimary":4282190851,"textSecondary":4288030226,"invertedBackground":4288030226,"overlayBackground":3426552835},"darkThemeColorPalette":{"baseBackground":4280157441,"raisedBackground":4282190851,"additiveBackground":736184365,"textPrimary":4294828765,"textSecondary":4294222740,"invertedBackground":4293756274,"overlayBackground":3426552835},"colorSampledDescriptionBodyText":{"content":"All of CHEMISTRY: GENERAL CHEMISTRY explained in 19 Minutes\n   • GENERAL CHEMISTRY explained in 19 Minutes  \n\nOh yeah also I have Instagram now: https://www.instagram.com/wacky.scien...\n\nPhysics is an amazing science, that is incredibly tedious to learn and notoriously difficult. \nLet's learn pretty much all of Physics in under 15 minutes.\nExplaining all of physics would take more than 14 minutes. \nObviously I can't get ALL of physics in that small timeframe, but I tried my best to get all of the stuff worth knowing for most people, and explaining it as simply as possible, as fast as possible ;)\n\nTimestamps:\n00:00 Classical Mechanics\n02:33 Energy\n04:40 Thermodynamics\n06:01 Electromagnetism\n08:30 Nuclear Physics 1\n09:28 Relativity\n11:25 Nuclear Physics 2\n12:13 Quantum Mechanics\n\nThis video took way too many hours to make. \nIf you like it, show it to your friends. Thanks\n\nMusic by Audionautix.com\n\nInspired by Arvin Ash's Video:    • All physics explained in 15 minutes (worth...  ","commandRuns":[{"startIndex":60,"length":48,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBMQ040EGAciEwjS-8iIrZyRAxWLdE8EHQ1OPQzKAQT474oF","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=5iTOphGnCtg","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"5iTOphGnCtg","startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr4---sn-o5t5uxa-pncd.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=e624cea611a70ad8\u0026ip=124.109.43.196\u0026initcwndbps=1181250\u0026mt=1764590480\u0026oweuc="}}}}}},"onTapOptions":{"accessibilityInfo":{"accessibilityLabel":"YouTube Channel Link: GENERAL CHEMISTRY explained in 19 Minutes"}}},{"startIndex":145,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBMQ040EGAciEwjS-8iIrZyRAxWLdE8EHQ1OPQxI-dyiw4OUooVkygEE-O-KBQ==","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbF9KRUk4Wkd4TEtLSERhb3FDZnhHY2c4MTRFZ3xBQ3Jtc0ttYnJ2dWVIR04wczZtWjJHTW9DSG9zWmpPdjFCSFRzTWVGbXJGYVZZVkZXVE4tSW8tN1dTLVEzVmRCZmJSOUJDYnpVRVpXM1ZUSjFYRk9BZm8zSGh6TmFScDVqQ3VydXRwR1k4QUdoLWVyWHJSTDBhdw\u0026q=h