},{"startIndex":740,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":745,"length":19,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":764,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":769,"length":171,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":940,"length":52,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"}],"backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294963952,"raisedBackground":4294963952,"additiveBackground":568412205,"textPrimary":4282190851,"textSecondary":4288030226,"invertedBackground":4288030226,"overlayBackground":3426552835},"darkThemeColorPalette":{"baseBackground":4280157441,"raisedBackground":4282190851,"additiveBackground":736184365,"textPrimary":4294828765,"textSecondary":4294222740,"invertedBackground":4293756274,"overlayBackground":3426552835},"colorSampledDescriptionBodyText":{"content":"All of CHEMISTRY: GENERAL CHEMISTRY explained in 19 Minutes\n   • GENERAL CHEMISTRY explained in 19 Minutes  \n\nOh yeah also I have Instagram now: https://www.instagram.com/wacky.scien...\n\nPhysics is an amazing science, that is incredibly tedious to learn and notoriously difficult. \nLet's learn pretty much all of Physics in under 15 minutes.\nExplaining all of physics would take more than 14 minutes. \nObviously I can't get ALL of physics in that small timeframe, but I tried my best to get all of the stuff worth knowing for most people, and explaining it as simply as possible, as fast as possible ;)\n\nTimestamps:\n00:00 Classical Mechanics\n02:33 Energy\n04:40 Thermodynamics\n06:01 Electromagnetism\n08:30 Nuclear Physics 1\n09:28 Relativity\n11:25 Nuclear Physics 2\n12:13 Quantum Mechanics\n\nThis video took way too many hours to make. \nIf you like it, show it to your friends. Thanks\n\nMusic by Audionautix.com\n\nInspired by Arvin Ash's Video:    • All physics explained in 15 minutes (worth...  ","commandRuns":[{"startIndex":60,"length":48,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBMQ040EGAciEwi5mqirrJyRAxUI7UkHHUYnKcHKAQRl_MJI","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=5iTOphGnCtg","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"5iTOphGnCtg","startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr4---sn-o5t5uxa-pncd.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=e624cea611a70ad8\u0026ip=124.109.43.196\u0026initcwndbps=1185000\u0026mt=1764590233\u0026oweuc=\u0026pxtags=Cg4KAnR4Egg1MTUzOTgzMA\u0026rxtags=Cg4KAnR4Egg1MTUzOTgzMA%2CCg4KAnR4Egg1MTUzOTgzMQ"}}}}}},"onTapOptions":{"accessibilityInfo":{"accessibilityLabel":"YouTube Channel Link: GENERAL CHEMISTRY explained in 19 Minutes"}}},{"startIndex":145,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBMQ040EGAciEwi5mqirrJyRAxUI7UkHHUYnKcFI-dyiw4OUooVkygEEZfzCSA==","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbDlJdFlRak1PSmtsWVpZZkNXelhDQ3ZDcGFId3xBQ3Jtc0ttSDI0NDNEZk1IeWo2VVpvQ2J6ZUg2NndwekZMUWh2MHdQS0lrMXBsbG9YVXF1emItV3QteVpsUkcxVnB5QXdwbDJOS3NDMnEyUWppcmNkR3pmMG0yTlNFdWo1alBUaG1zb2FKblNVYzBQZDRiOF9TTQ\u0026q=https%3A%2F%2Fwww.instagram.com%2Fwacky.science%3Figsh%3DMWUxYXA0NzE4cXpkNQ%253D%253D%26utm_source%3Dqr\u0026v=ZAqIoDhornk","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbDlJdFlRak1PSmtsWVpZZkNXelhDQ3ZDcGFId3xBQ3Jtc0ttSDI0NDNEZk1IeWo2VVpvQ2J6ZUg2NndwekZMUWh2MHdQS0lrMXBsbG9YVXF1emItV3QteVpsUkcxVnB5QXdwbDJOS3NDMnEyUWppcmNkR3pmMG0yTlNFdWo1alBUaG1zb2FKblNVYzB