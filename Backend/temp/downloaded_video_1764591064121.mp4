:13 Quantum Mechanics\n\nThis video took way too many hours to make. \nIf you like it, show it to your friends. Thanks\n\nMusic by Audionautix.com\n\nInspired by Arvin Ash's Video:    • All physics explained in 15 minutes (worth...  ","commandRuns":[{"startIndex":60,"length":48,"onTap":{"innertubeCommand":{"clickTrackingParams":"CMICEM2rARgBIhMIybfz_a2ckQMVkcBJBx3sMiq_ygEEOsFD4A==","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=5iTOphGnCtg","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"5iTOphGnCtg","startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr4---sn-o5t5uxa-pncd.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=e624cea611a70ad8\u0026ip=124.109.43.196\u0026initcwndbps=1166250\u0026mt=1764590718\u0026oweuc=\u0026pxtags=Cg4KAnR4Egg1MTY3OTU3MQ\u0026rxtags=Cg4KAnR4Egg1MTY3OTU3MA%2CCg4KAnR4Egg1MTY3OTU3MQ%2CCg4KAnR4Egg1MTY3OTU3Mw"}}}}}},"onTapOptions":{"accessibilityInfo":{"accessibilityLabel":"YouTube Channel Link: GENERAL CHEMISTRY explained in 19 Minutes"}}},{"startIndex":145,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CMICEM2rARgBIhMIybfz_a2ckQMVkcBJBx3sMiq_SPncosODlKKFZMoBBDrBQ-A=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbVJpelV5Tkpjb0VvSlRhWjZ5bW1BUU96UDVHd3xBQ3Jtc0trVHktR2VGSU5PQmc5NXFhTXA3MXVOZDhWQnBGTTFlaTNwYW9fUzIxMDZnWEExckE1UjZ5ckhMUnNqWXFHNTdDaXRGSkFRQW8ta0VUNjZhVFg0M0F4TTFFR0xQbE85eThPdTVHY1ZBYjJjaU1PWklCTQ\u0026q=https%3A%2F%2Fwww.instagram.com%2Fwacky.science%3Figsh%3DMWUxYXA0NzE4cXpkNQ%253D%253D%26utm_source%3Dqr\u0026v=ZAqIoDhornk","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026red